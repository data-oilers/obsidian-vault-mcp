GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-organization-name

# Audio Pipeline (Phase 4)
ANTHROPIC_API_KEY=sk-ant-your_key_here
AUDIO_WATCHER_LOG_LEVEL=info

# Team Members (override default emails si corresponde)
TEAM_ALICE_EMAIL=alice@company.com
TEAM_BOB_EMAIL=bob@company.com
TEAM_CHARLIE_EMAIL=charlie@company.com
TEAM_DIANA_EMAIL=diana@company.com
TEAM_EVE_EMAIL=eve@company.com
TEAM_FRANK_EMAIL=frank@company.com
TEAM_GRACE_EMAIL=grace@company.com
TEAM_HENRY_EMAIL=henry@company.com

# Obsidian Vault Paths (opcional — default: ~/Documentos/<NAME>)
# Descomentar solo si tus vaults están en otra ruta.
# VAULTS_FACULTAD_PATH=/ruta/absoluta/a/FACULTAD
# VAULTS_DATAOILERS_PATH=/ruta/absoluta/a/DATAOILERS
# VAULTS_PROYECTOS_PATH=/ruta/absoluta/a/PROYECTOS

# Repo Local Paths (opcional — default: ~/repos/data-oilers/<NAME>)
# Descomentar solo si clonaste los repos en otra ruta.
# REPO_ENTERPRISE_AI_PLATFORM_PATH=/ruta/absoluta/a/enterprise-ai-platform
# REPO_POC_MACRO_RIESGO_PATH=/ruta/absoluta/a/poc-macro-riesgo
