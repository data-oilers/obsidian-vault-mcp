GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-organization-name

# Audio Pipeline (Phase 4)
ANTHROPIC_API_KEY=sk-ant-your_key_here
AUDIO_WATCHER_LOG_LEVEL=info

# Team Members (override default emails si corresponde)
# Los nombres canonicos viven en src/config.ts > TEAM_MEMBERS.
# TEAM_Emiliano_EMAIL=emiliano@dataoilers.com
# TEAM_Emanuel_EMAIL=emanuel@dataoilers.com
# TEAM_Agustin_EMAIL=agustin@dataoilers.com
# TEAM_Lautaro_EMAIL=lautaro@dataoilers.com
# TEAM_Franco_EMAIL=franco@dataoilers.com
# TEAM_Branco_EMAIL=branco@dataoilers.com
# TEAM_Gaston_EMAIL=gaston@dataoilers.com
# TEAM_Eliezer_EMAIL=matias.rivero@dataoilers.com

# Obsidian Vault Paths (opcional — default: ~/Documentos/<NAME>)
# Descomentar solo si tu vault está en otra ruta.
# VAULTS_DATAOILERS_PATH=/ruta/absoluta/a/dataoilers-vault

# Repo Local Paths (opcional — default: ~/repos/data-oilers/<NAME>)
# Descomentar solo si clonaste los repos en otra ruta.
# REPO_ENTERPRISE_AI_PLATFORM_PATH=/ruta/absoluta/a/enterprise-ai-platform
# REPO_ITMIND_INFRASTRUCTURE_PATH=/ruta/absoluta/a/itmind-infrastructure
